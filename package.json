{
  "name": "ravensnest",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "commonjs",

  "scripts": {
    "dev": "concurrently \"node server/server.js\" \"cd client && npm start\" \"wait-on http://localhost:3000 && electron .\"",

    "start": "electron .",

    "server": "node server/server.js",
    "client": "cd client && npm start",

    "build-client": "cd client && npm run build",

    "dist": "npm run build-client && electron-builder"
  },

  "build": {
    "appId": "com.telegram.clone",
    "productName": "TelegramClone",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/build/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },

  "dependencies": {
    "concurrently": "^10.0.3",
    "wait-on": "^7.2.0"
  },

  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}